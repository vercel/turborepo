{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Run Duration (ms)",
      "description": "Histogram of turbo run durations in milliseconds",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(turbo_run_duration_ms_sum[5m]) / rate(turbo_run_duration_ms_count[5m])",
          "legendFormat": "avg duration",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(turbo_run_duration_ms_bucket[5m]))",
          "legendFormat": "p95 duration",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Runs Over Time",
      "description": "Number of turbo runs",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "pointSize": 5,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(turbo_run_duration_ms_count[5m])",
          "legendFormat": "runs",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Tasks Attempted",
      "description": "Total tasks attempted across runs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "turbo_run_tasks_attempted_total",
          "legendFormat": "attempted",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Tasks Cached",
      "description": "Tasks served from cache",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "turbo_run_tasks_cached_total",
          "legendFormat": "cached",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Tasks Failed",
      "description": "Tasks that failed during runs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "turbo_run_tasks_failed_total",
          "legendFormat": "failed",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Cache Hit Rate",
      "description": "Percentage of tasks served from cache",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "turbo_run_tasks_cached_total / clamp_min(turbo_run_tasks_attempted_total, 1)",
          "legendFormat": "hit rate",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Task Breakdown",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "collapsed": false,
      "panels": []
    },
    {
      "title": "Duration by Task",
      "description": "Total execution time per task type (build, lint, check-types, etc.)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "xTickLabelRotation": 0,
        "groupWidth": 0.7,
        "barWidth": 0.8
      },
      "targets": [
        {
          "expr": "turbo_task_duration_ms_sum",
          "legendFormat": "{{turbo_task_name}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "turbo_task_name": { "aggregations": [], "operation": "groupby" },
              "Value": { "aggregations": ["sum"], "operation": "aggregate" }
            }
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": {}, "sort": [{ "field": "Value (sum)", "desc": true }] }
        }
      ]
    },
    {
      "title": "Cache Status by Task",
      "description": "Cache hit vs miss breakdown per task type",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "normal",
        "xTickLabelRotation": 0,
        "groupWidth": 0.7,
        "barWidth": 0.8
      },
      "targets": [
        {
          "expr": "turbo_task_cache_events_total",
          "legendFormat": "{{turbo_task_name}} ({{turbo_task_cache_status}})",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "turbo_task_name": { "aggregations": [], "operation": "groupby" },
              "turbo_task_cache_status": { "aggregations": [], "operation": "groupby" },
              "Value": { "aggregations": ["sum"], "operation": "aggregate" }
            }
          }
        }
      ]
    },
    {
      "title": "Task Details",
      "description": "Per-task breakdown with duration, cache status, and package",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "unit", "value": "ms" }, { "id": "displayName", "value": "Duration (ms)" }]
          }
        ]
      },
      "targets": [
        {
          "expr": "turbo_task_duration_ms_sum",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "env": true,
              "instance": true,
              "job": true,
              "turbo_run_exit_code": true,
              "turbo_run_id": true,
              "turbo_scm_branch": true,
              "turbo_scm_revision": true,
              "turbo_task_cache_source": true,
              "turbo_task_cache_time_saved_ms": true,
              "turbo_task_command": true,
              "turbo_task_exit_code": true,
              "turbo_task_external_inputs_hash": true,
              "turbo_task_hash": true,
              "turbo_task_id": true,
              "turbo_version": true,
              "service_name": true
            },
            "renameByName": {
              "turbo_task_name": "Task",
              "turbo_task_package": "Package",
              "turbo_task_cache_status": "Cache Status",
              "Value": "Duration (ms)"
            },
            "indexByName": {
              "turbo_task_name": 0,
              "turbo_task_package": 1,
              "turbo_task_cache_status": 2,
              "Value": 3
            }
          }
        }
      ]
    },
    {
      "title": "Task Duration Over Time",
      "description": "How task durations change across runs",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "turbo_task_duration_ms_sum",
          "legendFormat": "{{turbo_task_name}} ({{turbo_task_package}})",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Cache Events Over Time",
      "description": "Cache hit/miss events per task over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal" },
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "turbo_task_cache_events_total",
          "legendFormat": "{{turbo_task_name}} ({{turbo_task_cache_status}})",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["turborepo", "otel"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Turborepo Runs",
  "uid": "turborepo-runs",
  "version": 1
}
