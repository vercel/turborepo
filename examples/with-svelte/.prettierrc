{
  "useTabs": true,
  "singleQuote": true,
  "trailingComma": "none",
  "printWidth": 100,
  "plugins": ["prettier-plugin-svelte"],
  "overrides": [
    {
      "files": ["*.svelte"],
      "options": {
        "bracketSameLine": false
      }
    },
    {
      "files": ["**/package.json", "**/README.md", ".prettierrc", "meta.json", "turbo.json"],
      "options": {
        "useTabs": false,
        "tabWidth": 2
      }
    }
  ]
}
