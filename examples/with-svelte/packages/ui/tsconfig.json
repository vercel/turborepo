{
  "extends": [
    "@repo/typescript-config/svelte.json",
    "./.svelte-kit/tsconfig.json"
  ],
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "allowArbitraryExtensions": true,
    "types": ["svelte"],
    "strictNullChecks": true
  },
  "include": ["./src/**/*.svelte", "./src/**/*.svelte.ts", "./src/**/*.ts"]
}
