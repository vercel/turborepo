{
  "name": "@repo/ui",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "svelte-kit sync && svelte-package --watch --input=src",
    "build": "svelte-kit sync && svelte-package --input=src",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:package": "publint",
    "check-types": "svelte-check --tsconfig ./tsconfig.json",
    "test:unit": "vitest run"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "src",
    "!src/**/*.test.*",
    "!src/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@sveltejs/kit": "catalog:sveltejs",
    "@sveltejs/package": "catalog:sveltejs",
    "@sveltejs/vite-plugin-svelte": "catalog:sveltejs",
    "@types/node": "^24.13.3",
    "@vitest/browser-playwright": "^4.1.10",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "publint": "^0.3.21",
    "svelte": "catalog:sveltejs",
    "svelte-check": "catalog:sveltejs",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "vitest-browser-svelte": "^2.2.1"
  }
}
