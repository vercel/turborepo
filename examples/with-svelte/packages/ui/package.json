{
  "name": "@repo/ui",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "svelte-kit sync && svelte-package --watch --input=src",
    "build": "svelte-kit sync && svelte-package --input=src",
    "lint": "eslint .",
    "lint:package": "publint",
    "check-types": "svelte-check --tsconfig ./tsconfig.json"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*",
    "src",
    "!src/**/*.test.*",
    "!src/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@sveltejs/adapter-auto": "catalog:sveltejs",
    "@sveltejs/kit": "catalog:sveltejs",
    "@sveltejs/package": "catalog:sveltejs",
    "@sveltejs/vite-plugin-svelte": "catalog:sveltejs",
    "@types/node": "^24.13.2",
    "@vitest/browser-playwright": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "catalog:sveltejs",
    "globals": "^17.6.0",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "catalog:sveltejs",
    "publint": "^0.3.21",
    "svelte": "catalog:sveltejs",
    "svelte-check": "catalog:sveltejs",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vitest-browser-svelte": "^2.1.1"
  }
}
