{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "prebuild",
        "^build"
      ],
      "outputs": [
        "output-file.txt",
        "dist/**"
      ]
    },
    "dev": {
      "cache": false,
      "interactive": true,
      "persistent": true
    },
    "prebuild": {},
    "lint": {},
    "check-types": {}
  }
}
