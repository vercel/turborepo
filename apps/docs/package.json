{
  "name": "docs",
  "description": "Turborepo documentation site, built on @vercel/geistdocs.",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "check-links": "cd content && node --experimental-strip-types ../../docs/link-checker/src/validate-docs-links.ts",
    "check-openapi": "node --experimental-strip-types scripts/generate-openapi-docs.ts --check",
    "check-types": "next typegen && fumadocs-mdx && tsc --noEmit",
    "collect-examples-data": "node --experimental-strip-types ./scripts/collect-examples-data.ts",
    "dev": "next dev",
    "generate:openapi": "node --experimental-strip-types scripts/generate-openapi-docs.ts",
    "lint": "fumadocs-mdx",
    "postinstall": "fumadocs-mdx",
    "schema": "node --experimental-strip-types scripts/copy-json-schema.ts",
    "start": "next start",
    "translate": "npx @vercel/geistdocs translate"
  },
  "dependencies": {
    "@icons-pack/react-simple-icons": "^13.8.0",
    "@shikijs/transformers": "^3.22.0",
    "@upstash/redis": "1.35.7",
    "@vercel/agent-readability": "^0.2.1",
    "@vercel/analytics": "^1.6.1",
    "@vercel/geistdocs": "^1.11.0",
    "@vercel/speed-insights": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "feed": "^5.1.0",
    "fumadocs-core": "16.2.2",
    "fumadocs-mdx": "14.0.4",
    "fumadocs-openapi": "10.10.3",
    "fumadocs-ui": "16.2.2",
    "geist": "^1.7.1",
    "linkedom": "0.18.12",
    "lucide-react": "^0.555.0",
    "motion": "^12.23.25",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "radix-ui": "latest",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "reactflow": "11.11.4",
    "shiki": "^3.22.0",
    "tailwind-merge": "^3.4.0",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-types": "^3.17.5",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@turbo/types": "workspace:*",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vercel/toolbar": "0.1.30",
    "gray-matter": "^4.0.3",
    "picomatch": "4.0.4",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "typescript": "npm:@typescript/typescript6@^6.0.1",
    "typescript-7": "npm:typescript@7.0.1-rc"
  }
}
