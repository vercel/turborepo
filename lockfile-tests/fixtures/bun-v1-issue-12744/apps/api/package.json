{
	"name": "@eventmate/api",
	"type": "module",
	"private": true,
	"exports": {
		".": {
			"default": "./src/index.ts",
			"types": "./src/index.ts"
		}
	},
	"scripts": {
		"dev": "bun run src/index.ts",
		"build": "bunx tsgo",
