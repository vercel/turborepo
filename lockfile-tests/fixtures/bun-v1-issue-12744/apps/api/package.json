    "@t3-oss/env-core": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "elysia": "catalog:",
    "pino": "^10.1.0",
    "pino-pretty": "catalog:",
    "prom-client": "catalog:",
