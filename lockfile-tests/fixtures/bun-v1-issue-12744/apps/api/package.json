		"@eventmate/permissions": "workspace:*",
		"@sinclair/typebox": "^0.34.49",
		"@t3-oss/env-core": "catalog:",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"elysia": "catalog:",
		"@openrouter/sdk": "^0.11.2",
		"sharp": "^0.34.5",
		"stripe": "^18.0.0",
		"pino": "^10.1.0",
		"pino-pretty": "catalog:",
		"prom-client": "catalog:",
		"zod": "catalog:zod4"
