{
  "name": "@eventmate/bot",
  "version": "1.0.46-beta",
  "license": "UNLICENSED",
  "author": "David Hermann <redeagle.private@gmail.com>",
  "main": "index.js",
  "scripts": {
    "start": "NODE_ENV=prod bun dist/index.js",
    "start:dev": "NODE_ENV=dev bun dist/index.js",
    "dev": "NODE_ENV=dev bun --watch src/index.ts",
    "build": "tsc && tsc-alias",
    "typecheck": "bunx tsgo --noEmit",
    "db:gen": "npx prisma generate --schema=./src/infrastructure/prisma/schema.prisma",
    "db:migrate": "dotenv -e .env.prod -- npx prisma migrate dev --schema=./src/infrastructure/prisma/schema.prisma",
    "db:push": "dotenv -e .env.dev -- npx prisma db push --schema=./src/infrastructure/prisma/schema.prisma",
    "db:up:test": "dotenv -e .env.test -- npx prisma db push --schema=./src/infrastructure/prisma/schema.prisma",
    "docs": "typedoc src/main/**/*.ts src/main/lib/classes/**/*.ts src/main/lib/embeds/**/*.ts src/main/lib/functions/**/*.ts src/main/lib/prisma/**/*.ts --out docs",
    "lint": "eslint . --ext .ts",
    "dev:seed": "dotenv -e .env.dev -- tsx src/infrastructure/prisma/seed.ts",
    "prod:seed": "dotenv -e .env.prod -- tsx src/infrastructure/prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@axiomhq/js": "catalog:",
    "@axiomhq/logging": "catalog:",
    "@elysiajs/eden": "catalog:",
    "@eventmate/api": "workspace:*",
    "@eventmate/audit": "workspace:*",
    "@eventmate/database": "workspace:*",
    "@eventmate/metrics": "workspace:*",
    "@eventmate/permissions": "workspace:*",
    "@t3-oss/env-core": "catalog:",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "async-mutex": "^0.5.0",
    "cors": "^2.8.5",
    "cron-parser": "catalog:",
    "discord.js": "^14.21.0",
    "dotenv": "catalog:",
    "express": "^5.1.0",
    "i18next": "^24.2.3",
    "i18next-fs-backend": "^2.6.0",
    "ioredis": "catalog:",
    "node-cron": "^4.2.1",
    "node-schedule": "^2.1.1",
    "pino": "catalog:pino9",
    "pino-pretty": "catalog:",
    "prom-client": "catalog:",
    "zod": "catalog:zod3"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@mermaid-js/mermaid-cli": "^11.9.0",
    "@types/ioredis": "catalog:",
    "@types/node": "catalog:",
    "@types/node-cron": "^3.0.11",
    "@types/node-schedule": "^2.1.8",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "@typescript/native-preview": "catalog:",
    "dotenv-cli": "^7.4.4",
    "elysia": "catalog:",
    "eslint": "^8.57.1",
    "eslint-plugin-deprecation": "^3.0.0",
    "globals": "^15.15.0",
    "puppeteer": "^24.16.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.4",
    "typedoc": "^0.26.11",
    "typescript": "catalog:",
    "typescript-eslint": "^8.39.1",
    "vitest": "catalog:"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
