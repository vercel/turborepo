{
  "name": "eventmate",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "clean": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && find . -name '.next' -type d -prune -exec rm -rf '{}' + && find . -name 'dist' -type d -prune -exec rm -rf '{}' + && find . -name '*.tsbuildinfo' -type f -delete && find . -name 'generated' -type d -prune -exec rm -rf '{}' + && find . -name 'zenstack' -type d -prune -exec rm -rf '{}' + && find . -name '.turbo' -type d -prune -exec rm -rf '{}' + && rm -rf out",
    "build": "turbo run build",
    "dev": "turbo run migrate dev",
    "lint": "turbo run lint",
    "check": "biome check .",
    "check:unsafe": "biome check --write --unsafe .",
    "check:write": "biome check --write .",
    "typecheck": "turbo typecheck",
    "generate": "turbo run generate",
    "migrate": "turbo run migrate"
  },
  "dependencies": {
    "@axiomhq/pino": "^1.3.1",
    "@biomejs/biome": "catalog:",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "11.16.0",
    "cron-parser": "catalog:",
    "pino": "^10.1.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.3",
    "@semantic-release/npm": "^12.0.1",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "semantic-release": "^24.2.5",
    "turbo": "2.9.7-canary.13",
    "typescript": "catalog:"
  },
  "overrides": {
    "@trpc/client": "11.16.0",
    "@trpc/react-query": "11.16.0",
    "@trpc/server": "11.16.0",
    "pg": "8.20.0"
  },
  "engines": {
