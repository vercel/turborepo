{
  "$schema": "../docs/public/schema.json",
  "extends": ["//"],
  // Building the turbo binary is handled natively: the `turbo` crate is a
  // Turborepo package with its own `build` task (`cargo build
  // --package=turbo`) and derived closure hashing. This package only hosts
  // release tooling.
  "tasks": {
    "release-native": {
      "dependsOn": ["@turbo/releaser#build"],
      "cache": false
    }
  }
}
